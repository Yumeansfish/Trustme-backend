  "categorizationKnowledgebaseVersion": 1,
  "devmode": false,
  "showYearly": false,
  "useMultidevice": false,
  "requestTimeout": 30,
  "deviceMappings": {
    "Office": ["alpha.local", "beta.local"]
  }
}
