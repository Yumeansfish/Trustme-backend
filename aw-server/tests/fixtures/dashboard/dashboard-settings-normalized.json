{
  "_schema_version": 1,
  "startOfDay": "09:00",
  "startOfWeek": "Monday",
  "durationDefault": 86400,
  "useColorFallback": false,
  "landingpage": "/activity",
  "theme": "dark",
  "always_active_pattern": "Zoom|Teams",
